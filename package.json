{
    "name": "@bric/rex-core",
    "version": "0.0.1",
    "description": "Core REX module providing services to other REX modules.",
    "keywords": [
        "extension",
        "rex"
    ],
    "author": "Behavioral Research Innovation Center",
    "type": "module",
    "homepage": "https://github.com/bric-digital/rex-core",
    "bugs": {
        "url": "https://github.com/bric-digital/rex-core/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bric-digital/rex-core.git"
    },
    "exports": {
        "./browser": "./src/browser.mts",
        "./common": "./src/common.mts",
        "./extension": "./src/extension.mts",
        "./service-worker": "./src/service-worker.mts"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint src",
        "pretest": "node tests/scripts/build-test-bundle.js",
        "test": "playwright test",
        "test:ci": "playwright test --reporter=dot",
        "test:debug": "playwright test --debug",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:unit": "playwright test specs/",
        "server": "node tests/scripts/run-server.js"
    },
    "dependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.1",
        "@types/jquery": "^4.0.1",
        "@types/psl": "^1.1.3",
        "bootstrap": "^5.3.8",
        "bootstrap-icons": "^1.13.1",
        "chrome-types": "^0.1.431",
        "esbuild": "^0.28.1",
        "eslint": "^10.6.0",
        "globals": "^17.7.0",
        "jiti": "^2.7.0",
        "jquery": "^4.0.0",
        "psl": "^1.15.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    },
    "devDependencies": {
        "express": "^5.2.1"
    }
}
