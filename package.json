{
    "name": "@bric/rex-core",
    "version": "0.0.1",
    "description": "Core REX module providing services to other REX modules.",
    "keywords": [
        "extension",
        "rex"
    ],
    "author": "Behavioral Research Innovation Center",
    "type": "module",
    "homepage": "https://github.com/bric-digital/rex-core",
    "bugs": {
        "url": "https://github.com/bric-digital/rex-core/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bric-digital/rex-core.git"
    },
    "exports": {
        "./extension": "./src/extension.mts",
        "./browser": "./src/browser.mts",
        "./service-worker": "./src/service-worker.mts"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint src",
        "pretest": "node tests/scripts/build-test-bundle.js",
        "test": "playwright test",
        "test:ci": "playwright test --reporter=dot",
        "test:debug": "playwright test --debug",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:unit": "playwright test specs/"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@playwright/test": "^1.58.2",
        "@types/jquery": "^3.5.33",
        "@types/psl": "^1.1.3",
        "chrome-types": "^0.1.415",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.1",
        "globals": "^17.3.0",
        "jiti": "^2.6.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.55.0"
    },
    "dependencies": {
        "jquery": "^4.0.0",
        "psl": "^1.15.0"
    }
}
